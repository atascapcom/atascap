---
import { pageHref } from '@data/translations';
import type { Lang } from '@data/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const text = {
  en: 'We use privacy-friendly, cookieless analytics. No tracking cookies are set.',
  es: 'Usamos analítica respetuosa con la privacidad, sin cookies. No se instalan cookies de seguimiento.',
  tr: 'Gizlilik dostu, çerezsiz analitik kullanıyoruz. Hiçbir takip çerezi yerleştirilmez.',
};

const moreLabel = {
  en: 'Privacy Policy',
  es: 'Política de Privacidad',
  tr: 'Gizlilik Politikası',
};

const dismissLabel = {
  en: 'Got it',
  es: 'Entendido',
  tr: 'Tamam',
};

const privacyHref = pageHref(lang, 'privacy');
---

<div class="cookie-banner" id="cookieBanner">
  <span>
    {text[lang]}{' '}
    <a href={privacyHref} style="color: #fff; text-decoration: underline;">{moreLabel[lang]}</a>
  </span>
  <div>
    <button onclick="dismissCookieNotice()">{dismissLabel[lang]}</button>
  </div>
</div>

<script>
  if (localStorage.getItem('noticeDismissed') !== null) {
    const banner = document.getElementById('cookieBanner');
    if (banner) banner.style.display = 'none';
  }

  (window as any).dismissCookieNotice = () => {
    localStorage.setItem('noticeDismissed', 'true');
    const banner = document.getElementById('cookieBanner');
    if (banner) banner.style.display = 'none';
  };
</script>
