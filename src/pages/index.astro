---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  lang="en"
  pageKey="home"
  title="Ataş Capital — Enduring Value"
  description="Ataş Capital is an independent, research-driven investment practice focused on the long-term preservation and growth of private capital."
>
  <section class="hero">
    <h1>ENDURING VALUE</h1>
    <p class="hero__subtitle">An independent investment practice devoted to the long-term preservation and compounding of capital.</p>
  </section>

  <section class="section section--bordered">
    <div class="container--narrow">
      <div class="content-block">
        <p>Ataş Capital is a research-driven investment practice focused on identifying and owning fundamentally undervalued businesses for the long term. Our work is dedicated to a limited circle of like-minded partners who share a disciplined investment philosophy rooted in patience, intellectual independence, and structural discipline.</p>
        <p>We emphasize deep analysis and business quality, seeking to understand a select number of companies whose enduring earning power is not yet reflected in their price. Our approach aims to protect and compound value over time — not through activity, but through conviction.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-card__value">2025</span>
          <span class="stat-card__label">Founded</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__value">Long-Term</span>
          <span class="stat-card__label">Investment Horizon</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__value">Concentrated</span>
          <span class="stat-card__label">Portfolio Approach</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__value">Private</span>
          <span class="stat-card__label">Capital Structure</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container--narrow">
      <div class="section__header">
        <h2>Our Philosophy</h2>
        <div class="divider"></div>
        <p>Investing is not speculation — it is partnership. We view ownership in a business as a commitment to long-term value creation, not as a short-term trade.</p>
      </div>
      <div class="content-block" style="text-align: center;">
        <p>
          <a href="/philosophy.html" style="font-family: var(--font-serif); font-size: var(--font-size-md); color: var(--color-accent); border-bottom: 1px solid var(--color-accent);">
            Read our investment philosophy →
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="section section--bordered">
    <div class="container--narrow">
      <div class="section__header">
        <h2>Latest Insights</h2>
        <div class="divider"></div>
      </div>
      <div class="empty-state">
        <p>Investor letters and insights coming soon.</p>
      </div>
    </div>
  </section>
</BaseLayout>
