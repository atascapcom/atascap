---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { sortLettersDesc, letterNumbers, letterSlug, periodLabel, letterNo } from '@data/letters';

const all = await getCollection('letters', ({ data }) => data.lang === 'en' && !data.draft);
const numbers = letterNumbers(all);
const latest = sortLettersDesc(all).slice(0, 2);
---

<BaseLayout
  lang="en"
  pageKey="home"
  title="Ataş Capital — Enduring Value"
  description="Ataş Capital is an independent, research-driven investment practice focused on the long-term preservation and growth of private capital."
>
  <section class="hero">
    <h1>ENDURING VALUE</h1>
    <p class="hero__subtitle">We seek to understand exceptional companies whose enduring earning power is not yet reflected in their prices.</p>
  </section>

  <section class="section section--bordered">
    <div class="container--narrow">
      <div class="content-block">
        <p>Ataş Capital researches and patiently takes ownership of businesses the market has not yet fully recognized, but which hold the potential to create extraordinary value over the long term.</p>
        <p>Most of what we do is not trading, but reading, thinking, and waiting. Because we believe that a significant part of investment results comes not from analysis, but from the ability to stay alongside the right idea for long enough.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-card__value">2024</span>
          <span class="stat-card__label">Founded</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__value">Long-Term</span>
          <span class="stat-card__label">Investment Horizon</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__value">Concentrated</span>
          <span class="stat-card__label">Portfolio Approach</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__value">Private</span>
          <span class="stat-card__label">Capital Structure</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container--narrow">
      <div class="section__header">
        <h2>Our Philosophy</h2>
        <div class="divider"></div>
        <p>Investing is not speculation — it is partnership. We view ownership in a business as a commitment to long-term value creation, not as a short-term trade.</p>
      </div>
      <div class="content-block" style="text-align: center;">
        <p>
          <a href="/philosophy.html" style="font-family: var(--font-serif); font-size: var(--font-size-md); color: var(--color-accent); border-bottom: 1px solid var(--color-accent);">
            Read our investment philosophy →
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="section section--bordered">
    <div class="container--narrow">
      <div class="section__header">
        <h2>Latest Insights</h2>
        <div class="divider"></div>
      </div>
      {latest.length > 0 ? (
        <>
          <ul class="letters-list">
            {latest.map((letter) => (
              <li class="letter-item">
                <span class="letter-item__date">
                  {periodLabel(letter.data.period, 'en') || letter.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                </span>
                <div class="letter-item__content">
                  <span class="letter-item__no">{letterNo(numbers.get(letter.slug) ?? 1)}</span>
                  <h3><a href={`/letters/${letterSlug(letter)}.html`}>{letter.data.title}</a></h3>
                  <p>{letter.data.description}</p>
                </div>
              </li>
            ))}
          </ul>
          <p style="text-align: center; margin-top: var(--space-xl);">
            <a href="/letters.html" style="font-family: var(--font-serif); font-size: var(--font-size-md); color: var(--color-accent); border-bottom: 1px solid var(--color-accent);">
              View all letters →
            </a>
          </p>
        </>
      ) : (
        <div class="empty-state">
          <p>Investor letters and insights coming soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
