---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { sortLettersDesc, letterNumbers, letterSlug, periodLabel, letterNo } from '@data/letters';

const all = await getCollection('letters', ({ data }) => data.lang === 'en' && !data.draft);
const numbers = letterNumbers(all);
const letters = sortLettersDesc(all);
---

<BaseLayout
  lang="en"
  pageKey="letters"
  title="Letters & Insights — Ataş Capital"
  description="Investor letters, market commentary, and investment insights from Ataş Capital."
>
  <section class="page-header">
    <h1>LETTERS &amp; INSIGHTS</h1>
    <p>Reflections on markets, investing, and the pursuit of lasting value.</p>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="content-block">
        <p>We believe that the best investors are also the clearest thinkers — and the best way to sharpen thinking is through writing. These letters share our perspective on markets, individual businesses, and the principles that guide our capital allocation decisions.</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container--narrow">
      {letters.length > 0 ? (
        <ul class="letters-list">
          {letters.map((letter) => (
            <li class="letter-item">
              <span class="letter-item__date">
                {periodLabel(letter.data.period, 'en') || letter.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
              </span>
              <div class="letter-item__content">
                <span class="letter-item__no">{letterNo(numbers.get(letter.slug) ?? 1)}</span>
                <h3>
                  <a href={`/letters/${letterSlug(letter)}.html`}>{letter.data.title}</a>
                </h3>
                <p>{letter.data.description}</p>
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty-state">
          <p>Our first investor letter is being prepared.</p>
          <p style="margin-top: var(--space-sm); font-size: var(--font-size-sm); font-style: normal; color: var(--color-text-light);">
            Follow us on LinkedIn or check back for our first letter.
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

